{
  "name": "@fmweb/designer-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.tsx --bundle --platform=browser --format=iife --outfile=dist/index.js --sourcemap",
    "dev": "esbuild src/main.tsx --bundle --platform=browser --format=iife --outfile=dist/index.js --sourcemap --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fmweb/shared": "file:../shared",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.25.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.3"
  }
}
