{
  "name": "filemaker-data-api-tools",
  "displayName": "FileMaker Data API Tools",
  "description": "VS Code tools for working with the FileMaker Data API (fmrest).",
  "version": "0.5.1",
  "publisher": "your-org",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://example.com/your-org/filemaker-data-api-tools.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:filemakerExplorer",
    "onCommand:filemakerDataApiTools.addConnectionProfile",
    "onCommand:filemakerDataApiTools.editConnectionProfile",
    "onCommand:filemakerDataApiTools.removeConnectionProfile",
    "onCommand:filemakerDataApiTools.connect",
    "onCommand:filemakerDataApiTools.disconnect",
    "onCommand:filemakerDataApiTools.listLayouts",
    "onCommand:filemakerDataApiTools.runFindJson",
    "onCommand:filemakerDataApiTools.getRecordById",
    "onCommand:filemakerDataApiTools.openRecordViewer",
    "onCommand:filemakerDataApiTools.openQueryBuilder",
    "onCommand:filemakerDataApiTools.openLayoutMetadata",
    "onCommand:filemakerDataApiTools.refreshSchemaCache",
    "onCommand:filemakerDataApiTools.openScriptRunner",
    "onCommand:filemakerDataApiTools.saveCurrentQuery",
    "onCommand:filemakerDataApiTools.runSavedQuery",
    "onCommand:filemakerDataApiTools.openSavedQuery",
    "onCommand:filemakerDataApiTools.manageSavedQueries",
    "onCommand:filemakerDataApiTools.exportSavedQueries",
    "onCommand:filemakerDataApiTools.importSavedQueries",
    "onCommand:filemakerDataApiTools.deleteSavedQuery",
    "onCommand:filemakerDataApiTools.showRequestHistory",
    "onCommand:filemakerDataApiTools.refreshExplorer",
    "onCommand:filemakerDataApiTools.captureSchemaSnapshot",
    "onCommand:filemakerDataApiTools.diffSchemaSnapshots",
    "onCommand:filemakerDataApiTools.diffAgainstLatestSnapshot",
    "onCommand:filemakerDataApiTools.openSchemaSnapshotJson",
    "onCommand:filemakerDataApiTools.generateTypesForLayout",
    "onCommand:filemakerDataApiTools.generateTypesForAllLayouts",
    "onCommand:filemakerDataApiTools.generateSnippetsForLayout",
    "onCommand:filemakerDataApiTools.openGeneratedTypesFolder",
    "onCommand:filemakerDataApiTools.openRecordEditor",
    "onCommand:filemakerDataApiTools.editRecordById",
    "onCommand:filemakerDataApiTools.batchExportFind",
    "onCommand:filemakerDataApiTools.batchUpdateFromFile",
    "onCommand:filemakerDataApiTools.showJobs",
    "onCommand:filemakerDataApiTools.createEnvironmentSet",
    "onCommand:filemakerDataApiTools.compareEnvironments",
    "onCommand:filemakerDataApiTools.diffLayoutAcrossEnvironments",
    "onCommand:filemakerDataApiTools.exportEnvironmentComparisonReport",
    "onCommand:filemakerDataApiTools.openEnvironmentSetJson",
    "onCommand:filemakerDataApiTools.openDiagnosticsDashboard",
